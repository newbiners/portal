---
import MainLayout from "../../layouts/mainlayout.astro";
import { getJobs, getJobById } from "../../services/jobService";
import { getProvinces, getCities } from "../../services/applicationService";
import {
  UploadCloud,
  User,
  Mail,
  Phone,
  MapPin,
  ChevronDown,
  GraduationCap,
  Wallet,
  FileText,
  Send,
  CheckCircle2,
  X,
} from "lucide-astro";

interface JobEntry {
  _id: string;
  title: string;
  slug: string;
  summary: string;
  description: string;
  requirement: string;
}

export async function getStaticPaths() {
  try {
    const response = await getJobs();
    const jobs: JobEntry[] = response?.entries ?? [];

    if (!jobs || jobs.length === 0) {
      console.warn("No jobs found for apply static path generation");
      return [];
    }

    return jobs.map((job: JobEntry) => ({
      params: { id: String(job._id) },
    }));
  } catch (err) {
    console.error("Error in getStaticPaths:", err);
    return [];
  }
}

// ambil id job dari URL (nanti bisa dipakai kirim ke API)
const { id } = Astro.params;

// ambil detail job yang dilamar untuk menampilkan judul di header
const job = id ? await getJobById(id) : null;
const appliedJobTitle = String(job?.title || "Job Application");

const provinceResponse = await getProvinces();
const cityResponse = await getCities();
const provinces = (provinceResponse && provinceResponse.entries) || [];
const cities = (cityResponse && cityResponse.entries) || [];
---

<MainLayout title="Apply Job">
  <!-- ================= HEADER ================= -->
  <section class="bg-linear-to-r from-blue-500 to-blue-400 h-12.5"></section>

  <!-- ================= OVERLAP CARD ================= -->
  <div class="w-[50%] max-w-5xl mx-auto -mt-6 relative z-10 text-center">
    <p
      class="text-lg md:text-xl font-semibold text-blue-600 bg-blue-50 px-6 py-3 shadow-lg rounded-full inline-block"
    >
      {appliedJobTitle}
    </p>
  </div>

  <script
    id="location-data"
    type="application/json"
    set:html={JSON.stringify({ provinces, cities })}
  />

  <script type="module">
    // Client logic: load provinces/cities and handle form submit
    document.addEventListener("DOMContentLoaded", () => {
      const form = document.querySelector("form");
      const portfolioInput = document.getElementById("portfolio");
      const portfolioPreview = document.getElementById("portfolio-preview");
      const portfolioPreviewName = document.getElementById(
        "portfolio-preview-name",
      );
      const portfolioPreviewBadge = document.getElementById(
        "portfolio-preview-badge",
      );
      const portfolioPreviewIcon = document.getElementById(
        "portfolio-preview-icon",
      );
      const portfolioPreviewRemove = document.getElementById(
        "portfolio-preview-remove",
      );
      const jobIdInput = form.querySelector('input[name="job_id"]');

      function findSelectByLabel(text) {
        const labels = Array.from(document.querySelectorAll("label"));
        for (const lab of labels) {
          if (lab.textContent && lab.textContent.trim().includes(text)) {
            return lab.parentElement.querySelector("select");
          }
        }
        return null;
      }

      function findInputByLabel(text) {
        const labels = Array.from(document.querySelectorAll("label"));
        for (const lab of labels) {
          if (lab.textContent && lab.textContent.trim().includes(text)) {
            return lab.parentElement.querySelector("input");
          }
        }
        return null;
      }

      const provinceSelect =
        findSelectByLabel("Province") || document.querySelector("select");
      const citySelect =
        findSelectByLabel("City") ||
        document.querySelectorAll("select")[1] ||
        null;
      const nameInput =
        findInputByLabel("Full Name") ||
        form.querySelector('input[placeholder="Johnathan Doe"]');
      const emailInput = form.querySelector('input[type="email"]');
      const whatsappInput =
        findInputByLabel("Phone Number") ||
        form.querySelector('input[placeholder="081234567890"]');
      const salaryInput = document.getElementById("salary");
      const educationSelect =
        document.getElementById("education") ||
        findSelectByLabel("Education") ||
        document.querySelectorAll("select")[2];

      const provincePlaceholder = '<option value="">Select Province</option>';
      const cityPlaceholder =
        '<option value="">Select City</option><option value="">Choose a province first</option>';

      const locationDataEl = document.getElementById("location-data");
      const locationData = locationDataEl
        ? JSON.parse(locationDataEl.textContent || "{}")
        : { provinces: [], cities: [] };
      const allProvinces = Array.isArray(locationData.provinces)
        ? locationData.provinces
        : [];
      const allCities = Array.isArray(locationData.cities)
        ? locationData.cities
        : [];
      const provinceIdToLegacyId = new Map(
        allProvinces.map((province) => [
          String(province._id || province.id || province.prov_id || ""),
          province.prov_id || province._id || province.id || "",
        ]),
      );
      const portfolioMaxSizeBytes = 5 * 1024 * 1024;

      function getPortfolioValidationError(file) {
        if (!file) return "";

        const fileName = String(file.name || "").toLowerCase();
        const fileType = String(file.type || "").toLowerCase();
        const isPdf =
          fileType === "application/pdf" || fileName.endsWith(".pdf");

        if (!isPdf) {
          return "Portofolio hanya boleh berupa file PDF.";
        }

        if (
          typeof file.size === "number" &&
          file.size > portfolioMaxSizeBytes
        ) {
          return "Ukuran file portofolio maksimal 5 MB.";
        }

        return "";
      }

      function formatDateOnly(date = new Date()) {
        return date.toISOString().slice(0, 10);
      }

      function getFileTypeLabel(file) {
        const mime = String(file?.type || "").trim();
        if (mime) return mime;

        const name = String(file?.name || "").toLowerCase();
        const ext = name.includes(".") ? name.split(".").pop() : "";
        if (!ext) return "Unknown file type";

        const extensionMap = {
          pdf: "application/pdf",
          doc: "application/msword",
          docx: "application/vnd.openxmlformats-officedocument.wordprocessingml.document",
          txt: "text/plain",
        };

        return extensionMap[ext] || `${ext.toUpperCase()} file`;
      }

      function updatePortfolioPreview(file) {
        if (!portfolioPreview || !portfolioPreviewName) {
          return;
        }

        if (!file) {
          portfolioPreview.classList.add("hidden");
          portfolioPreviewName.textContent = "";
          if (portfolioPreviewBadge)
            portfolioPreviewBadge.textContent = "No file selected";
          if (portfolioPreviewIcon) portfolioPreviewIcon.textContent = "";
          return;
        }

        const fileName = file.name || "Untitled file";

        if (portfolioPreviewBadge)
          portfolioPreviewBadge.textContent = "File selected";
        if (portfolioPreviewIcon) portfolioPreviewIcon.textContent = "PDF";
        portfolioPreviewName.textContent = fileName;
        portfolioPreview.classList.remove("hidden");
      }

      function clearPortfolioSelection() {
        if (portfolioInput) {
          portfolioInput.value = "";
        }
        updatePortfolioPreview(null);
      }

      if (portfolioInput) {
        portfolioInput.addEventListener("change", () => {
          const file = portfolioInput.files?.[0] || null;
          const validationError = getPortfolioValidationError(file);

          if (validationError) {
            portfolioInput.setCustomValidity(validationError);
            portfolioInput.reportValidity();
            clearPortfolioSelection();
            return;
          }

          portfolioInput.setCustomValidity("");
          updatePortfolioPreview(file);
        });
      }

      if (portfolioPreviewRemove) {
        portfolioPreviewRemove.addEventListener("click", () => {
          clearPortfolioSelection();
        });
      }

      // Format salary input
      function formatRupiahFromDigits(digits) {
        if (!digits) return "";
        return "Rp. " + digits.replace(/\B(?=(\d{3})+(?!\d))/g, ".");
      }

      if (salaryInput) {
        salaryInput.addEventListener("input", (e) => {
          const raw = String(e.target.value || "").replace(/\D/g, "");
          if (!raw) {
            e.target.value = "";
            return;
          }
          e.target.value = formatRupiahFromDigits(raw);
        });
      }

      function setCityDisabledState(isDisabled) {
        citySelect.disabled = isDisabled;
        citySelect.classList.toggle("bg-gray-100", isDisabled);
        citySelect.classList.toggle("cursor-not-allowed", isDisabled);
      }

      async function loadProvinces() {
        provinceSelect.innerHTML = provincePlaceholder;
        allProvinces.forEach((e) => {
          const opt = document.createElement("option");
          opt.value = e._id || e.id || e.prov_id;
          opt.textContent = e.name || e.title || String(opt.value);
          provinceSelect.appendChild(opt);
        });
      }

      async function loadCities(provinceValue) {
        const legacyProvId = provinceIdToLegacyId.get(String(provinceValue));
        if (!legacyProvId) {
          citySelect.innerHTML = cityPlaceholder;
          setCityDisabledState(true);
          citySelect.value = "";
          return;
        }

        try {
          const entries = allCities.filter(
            (entry) => String(entry.prov_id) === String(legacyProvId),
          );
          citySelect.innerHTML = '<option value="">Select City</option>';
          entries.forEach((e) => {
            const opt = document.createElement("option");
            opt.value = e._id || e.id;
            opt.textContent = e.name || e.kota || e.city || String(opt.value);
            citySelect.appendChild(opt);
          });
          setCityDisabledState(false);
        } catch (err) {
          console.error("Failed to load cities", err);
          citySelect.innerHTML = cityPlaceholder;
          setCityDisabledState(true);
        }
      }

      function handleProvinceChange(event) {
        const selectedProvinceValue = event.target.value;
        provinceSelect.setCustomValidity("");
        if (citySelect) citySelect.setCustomValidity("");

        citySelect.value = "";
        if (!selectedProvinceValue) {
          citySelect.innerHTML = cityPlaceholder;
          setCityDisabledState(true);
          return;
        }

        loadCities(selectedProvinceValue);
      }

      function handleCityFocus() {
        if (provinceSelect?.value) return;

        provinceSelect.setCustomValidity(
          "Silakan pilih province terlebih dahulu",
        );
        provinceSelect.reportValidity();
        provinceSelect.setCustomValidity("");
        citySelect.blur();
      }

      async function initializeLocationSelects() {
        await loadProvinces();
        citySelect.innerHTML = cityPlaceholder;
        setCityDisabledState(true);
      }

      // initial load
      initializeLocationSelects();

      if (provinceSelect)
        provinceSelect.addEventListener("change", handleProvinceChange);
      if (citySelect) citySelect.addEventListener("focus", handleCityFocus);

      form.addEventListener("submit", async (ev) => {
        ev.preventDefault();
        const submitBtn = form.querySelector('button[type="submit"]');
        if (submitBtn) submitBtn.disabled = true;

        // Validate required fields
        const validationErrors = [];

        if (!nameInput?.value || !String(nameInput.value).trim()) {
          validationErrors.push("Full Name is required");
          nameInput?.setCustomValidity("Full Name is required");
          nameInput?.reportValidity();
        } else {
          nameInput?.setCustomValidity("");
        }

        if (!emailInput?.value || !String(emailInput.value).trim()) {
          validationErrors.push("Email Address is required");
          emailInput?.setCustomValidity("Email Address is required");
          emailInput?.reportValidity();
        } else {
          emailInput?.setCustomValidity("");
        }

        if (!whatsappInput?.value || !String(whatsappInput.value).trim()) {
          validationErrors.push("Phone Number is required");
          whatsappInput?.setCustomValidity("Phone Number is required");
          whatsappInput?.reportValidity();
        } else {
          whatsappInput?.setCustomValidity("");
        }

        if (!salaryInput?.value || !String(salaryInput.value).trim()) {
          validationErrors.push("Expected Salary is required");
          salaryInput?.setCustomValidity("Expected Salary is required");
          salaryInput?.reportValidity();
        } else {
          salaryInput?.setCustomValidity("");
        }

        if (
          !educationSelect?.value ||
          String(educationSelect.value).trim() === ""
        ) {
          validationErrors.push("Education is required");
          educationSelect?.setCustomValidity("Education is required");
          educationSelect?.reportValidity();
        } else {
          educationSelect?.setCustomValidity("");
        }

        if (!provinceSelect?.value) {
          provinceSelect.setCustomValidity(
            "Silakan pilih province terlebih dahulu",
          );
          provinceSelect.reportValidity();
          provinceSelect.setCustomValidity("");
          if (submitBtn) submitBtn.disabled = false;
          return;
        }

        if (!citySelect?.value) {
          citySelect.setCustomValidity("Silakan pilih city terlebih dahulu");
          citySelect.reportValidity();
          citySelect.setCustomValidity("");
          if (submitBtn) submitBtn.disabled = false;
          return;
        }

        if (validationErrors.length > 0) {
          alert(
            "Please fill in all required fields:\n" +
              validationErrors.join("\n"),
          );
          if (submitBtn) submitBtn.disabled = false;
          return;
        }

        try {
          const fd = new FormData();

          // Required fields mapping
          if (jobIdInput) fd.append("job_posting", jobIdInput.value || "");
          if (nameInput) fd.append("candidate_name", nameInput.value || "");
          if (provinceSelect) fd.append("provinsi", provinceSelect.value || "");
          if (citySelect) fd.append("kota", citySelect.value || "");
          if (emailInput) fd.append("email", emailInput.value || "");
          if (whatsappInput) fd.append("whatsapp", whatsappInput.value || "");
          if (salaryInput) {
            const rawSalary = String(salaryInput.value || "").replace(
              /\D/g,
              "",
            );
            fd.append("ekspektasi_gaji", rawSalary);
          }
          if (educationSelect)
            fd.append("pendidikan", educationSelect.value || "");

          // file
          const file = portfolioInput?.files?.[0];
          if (file) {
            const validationError = getPortfolioValidationError(file);
            if (validationError) {
              portfolioInput?.setCustomValidity(validationError);
              portfolioInput?.reportValidity();
              if (submitBtn) submitBtn.disabled = false;
              return;
            }

            portfolioInput?.setCustomValidity("");
            fd.append("portofolio", file, file.name);
          }

          // additional fields
          fd.append("date", formatDateOnly());
          fd.append("stage_notes", "");

          const resp = await fetch("/api/submit-application", {
            method: "POST",
            body: fd,
          });
          const json = await resp.json();
          if (resp.ok && json.ok) {
            alert("Application submitted successfully");
            // Redirect to question page
            const jobId = jobIdInput.value;
            const applicationId =
              json?.result?._id ||
              json?.result?.entry?._id ||
              json?.result?.data?._id ||
              "";

            if (applicationId) {
              window.location.href = `/question/${jobId}?application_id=${encodeURIComponent(applicationId)}`;
            } else {
              // Fallback keeps old flow if API shape changes unexpectedly
              window.location.href = `/question/${jobId}`;
            }
          } else {
            throw new Error(json.error || "Submission failed");
          }
        } catch (err) {
          console.error(err);
          alert("Failed to submit application: " + err.message);
        } finally {
          if (submitBtn) submitBtn.disabled = false;
        }
      });
    });
  </script>

  <!-- ================= FORM ================= -->
  <section class="bg-white py-14">
    <div class="w-[90%] max-w-7xl mx-auto">
      <!-- CARD -->
      <div
        class="bg-white rounded-[28px] shadow-sm border border-gray-100 p-8 md:p-10"
      >
        <!-- TITLE -->
        <div class="flex items-center gap-3 mb-8">
          <div
            class="w-11 h-11 rounded-xl bg-blue-100 flex items-center justify-center"
          >
            <User class="text-blue-600" size={22} />
          </div>

          <div>
            <h2 class="text-2xl font-semibold text-gray-800">
              Application Form
            </h2>
            <p class="text-sm text-gray-500">
              Complete your application details
            </p>
          </div>
        </div>

        <!-- FORM -->
        <form class="space-y-6">
          <!-- Hidden job_id field -->
          <input type="hidden" name="job_id" value={id} />

          <!-- FULL NAME -->
          <div>
            <label
              class="text-sm font-semibold text-gray-700 mb-2 block text-left"
            >
              Full Name
            </label>

            <div class="relative">
              <User
                size={18}
                class="absolute left-4 top-1/2 -translate-y-1/2 text-gray-400"
              />

              <input
                type="text"
                placeholder="Johnathan Doe"
                required
                class="w-full bg-[#F5F7FB] border border-transparent rounded-xl pl-12 pr-4 py-3.5 outline-none text-black placeholder:text-gray-300 focus:border-blue-400 focus:ring-4 focus:ring-blue-100 transition"
              />
            </div>
          </div>

          <!-- EMAIL + PHONE -->
          <div class="grid md:grid-cols-2 gap-5">
            <!-- EMAIL -->
            <div>
              <label
                class="text-sm font-semibold text-gray-700 mb-2 block text-left"
              >
                Email Address
              </label>

              <div class="relative">
                <Mail
                  size={18}
                  class="absolute left-4 top-1/2 -translate-y-1/2 text-gray-400"
                />

                <input
                  type="email"
                  placeholder="john@example.com"
                  required
                  class="w-full bg-[#F5F7FB] border border-transparent rounded-xl pl-12 pr-4 py-3.5 outline-none text-black placeholder:text-gray-300 focus:border-blue-400 focus:ring-4 focus:ring-blue-100 transition"
                />
              </div>
            </div>

            <!-- PHONE -->
            <div>
              <label
                class="text-sm font-semibold text-gray-700 mb-2 block text-left"
              >
                Phone Number (WhatsApp)
              </label>

              <div class="relative">
                <Phone
                  size={18}
                  class="absolute left-4 top-1/2 -translate-y-1/2 text-gray-400"
                />

                <input
                  type="text"
                  placeholder="081234567890"
                  required
                  class="w-full bg-[#F5F7FB] border border-transparent rounded-xl pl-12 pr-4 py-3.5 outline-none text-black placeholder:text-gray-300 focus:border-blue-400 focus:ring-4 focus:ring-blue-100 transition"
                />
              </div>
            </div>
          </div>

          <!-- PROVINCE + CITY -->
          <div class="grid md:grid-cols-2 gap-5">
            <!-- PROVINCE -->
            <div>
              <label
                class="text-sm font-semibold text-gray-700 mb-2 block text-left"
              >
                Province
              </label>

              <div class="relative">
                <MapPin
                  size={18}
                  class="absolute left-4 top-1/2 -translate-y-1/2 text-gray-400 pointer-events-none"
                />

                <select
                  required
                  class="appearance-none w-full bg-[#F5F7FB] border border-transparent rounded-xl pl-12 pr-12 py-3.5 outline-none focus:border-blue-400 focus:ring-4 focus:ring-blue-100 transition text-gray-700"
                >
                  <option value="">Select Province</option>
                </select>

                <ChevronDown
                  size={18}
                  class="absolute right-4 top-1/2 -translate-y-1/2 text-gray-400 pointer-events-none"
                />
              </div>
            </div>

            <!-- CITY -->
            <div>
              <label
                class="text-sm font-semibold text-gray-700 mb-2 block text-left"
              >
                City
              </label>

              <div class="relative">
                <MapPin
                  size={18}
                  class="absolute left-4 top-1/2 -translate-y-1/2 text-gray-400 pointer-events-none"
                />

                <select
                  required
                  class="appearance-none w-full bg-[#F5F7FB] border border-transparent rounded-xl pl-12 pr-12 py-3.5 outline-none focus:border-blue-400 focus:ring-4 focus:ring-blue-100 transition text-gray-700"
                >
                  <option value="">Select City</option>
                </select>

                <ChevronDown
                  size={18}
                  class="absolute right-4 top-1/2 -translate-y-1/2 text-gray-400 pointer-events-none"
                />
              </div>
            </div>
          </div>

          <!-- SALARY + EDUCATION -->
          <div class="grid md:grid-cols-2 gap-5">
            <!-- SALARY -->
            <div>
              <label
                class="text-sm font-semibold text-gray-700 mb-2 block text-left"
              >
                Expected Salary (IDR)
              </label>

              <div class="relative">
                <Wallet
                  size={18}
                  class="absolute left-4 top-1/2 -translate-y-1/2 text-gray-400"
                />

                <input
                  id="salary"
                  type="text"
                  placeholder="Rp. 4.000.000"
                  required
                  class="w-full bg-[#F5F7FB] border border-transparent rounded-xl pl-12 pr-4 py-3.5 outline-none text-black placeholder:text-gray-300 focus:border-blue-400 focus:ring-4 focus:ring-blue-100 transition"
                />
              </div>
            </div>

            <!-- EDUCATION -->
            <div>
              <label
                class="text-sm font-semibold text-gray-700 mb-2 block text-left"
              >
                Education
              </label>

              <div class="relative">
                <GraduationCap
                  size={18}
                  class="absolute left-4 top-1/2 -translate-y-1/2 text-gray-400 pointer-events-none"
                />

                <select
                  id="education"
                  required
                  class="appearance-none w-full bg-[#F5F7FB] border border-transparent rounded-xl pl-12 pr-12 py-3.5 outline-none focus:border-blue-400 focus:ring-4 focus:ring-blue-100 transition text-gray-700"
                >
                  <option value="">Select Education</option>
                  <option value="SMA/SMK">SMA/SMK</option>
                  <option value="Diploma">Diploma</option>
                  <option value="Sarjana (s1)">Sarjana (S1)</option>
                  <option value="Magister (s2)">Magister (S2)</option>
                  <option value="Doktor (s3)">Doktor (S3)</option>
                </select>

                <ChevronDown
                  size={18}
                  class="absolute right-4 top-1/2 -translate-y-1/2 text-gray-400 pointer-events-none"
                />
              </div>
            </div>
          </div>

          <!-- UPLOAD -->
          <div>
            <label
              class="text-sm font-semibold text-gray-700 mb-3 block text-left"
            >
              Upload Portfolio
            </label>

            <input
              type="file"
              name="portofolio"
              id="portfolio"
              accept=".pdf,application/pdf"
              class="hidden"
            />

            <label
              for="portfolio"
              class="group border-2 border-dashed border-gray-300 hover:border-blue-400 rounded-2xl py-12 px-6 flex flex-col items-center justify-center text-center cursor-pointer transition bg-[#FAFBFD]"
            >
              <div
                class="w-16 h-16 rounded-2xl bg-blue-100 flex items-center justify-center mb-4 group-hover:scale-105 transition"
              >
                <UploadCloud class="text-blue-600" size={28} />
              </div>

              <h3 class="font-semibold text-gray-700">
                Upload your portfolio or CV
              </h3>

              <p class="text-sm text-gray-500 mt-2">
                Click to upload or drag and drop files here
              </p>

              <div
                class="mt-4 inline-flex items-center gap-2 text-xs bg-gray-100 text-gray-600 px-3 py-1 rounded-full"
              >
                <FileText size={14} />
                PDF (max 5MB)
              </div>
            </label>

            <div
              id="portfolio-preview"
              class="hidden mt-4 rounded-2xl border border-blue-100 bg-blue-50/70 p-4 shadow-sm"
            >
              <div class="flex items-start gap-4">
                <div
                  id="portfolio-preview-icon"
                  class="w-12 h-12 rounded-xl bg-white flex items-center justify-center text-[10px] font-bold tracking-[0.24em] text-blue-600 border border-blue-100 flex-none"
                >
                </div>

                <div class="min-w-0 flex-1">
                  <p
                    id="portfolio-preview-name"
                    class="mt-2 text-sm font-semibold text-slate-800 truncate"
                  >
                  </p>
                </div>

                <button
                  id="portfolio-preview-remove"
                  type="button"
                  class="inline-flex h-9 w-9 items-center justify-center rounded-full border border-blue-100 bg-white text-slate-500 hover:text-slate-800 hover:border-blue-200 transition"
                  aria-label="Remove selected file"
                >
                  <X size={16} />
                </button>
              </div>
            </div>
          </div>

          <!-- HIDDEN -->
          <input type="hidden" value={id} name="job_id" />

          <!-- BUTTON -->
          <div class="pt-2">
            <button
              type="submit"
              class="bg-blue-600 hover:bg-blue-700 active:scale-[0.98] transition text-white font-medium px-8 py-3.5 rounded-xl shadow-lg shadow-blue-200 flex items-center gap-2"
            >
              <Send size={18} />
              Next
            </button>
          </div>
        </form>
      </div>
    </div>
  </section>
</MainLayout>
