---
import MainLayout from "../layouts/mainlayout.astro";
import { getJobById } from "../services/jobService";
import {
  Check,
  BriefcaseBusiness,
  MapPin,
  TriangleAlert,
  Info,
  Copy,
} from "lucide-astro";

export const prerender = false;

const applicationId = String(
  Astro.url.searchParams.get("application_id") || "",
).trim();
const jobId = String(Astro.url.searchParams.get("job_id") || "").trim();
const job = jobId ? await getJobById(jobId) : null;
const appliedJobTitle = String(job?.title || "Posisi yang dilamar");
---

<MainLayout title="Application Success">
  <!-- ================= HERO ================= -->
  <section class="success-hero bg-linear-to-r from-blue-500 to-blue-400 h-22.5">
  </section>

  <!-- ================= CONTENT ================= -->
  <section class="success-content bg-[#f5f7fb] min-h-screen py-16">
    <div class="w-[90%] max-w-xl mx-auto text-center">
      <!-- SUCCESS ICON -->
      <div class="success-icon-wrap flex justify-center">
        <div
          class="success-icon w-28 h-28 rounded-full bg-white shadow-xl flex items-center justify-center"
        >
          <div
            class="success-icon-core w-16 h-16 rounded-full bg-blue-500 flex items-center justify-center"
          >
            <Check class="text-white" size={38} strokeWidth={3} />
          </div>
        </div>
      </div>

      <!-- TITLE -->
      <div class="success-title-wrap mt-8">
        <h1 class="success-title text-3xl font-bold text-slate-800">
          Application Submitted!
        </h1>

        <p class="success-subtitle text-slate-500 mt-4 text-lg">
          Your application for this position has been successfully submitted.
        </p>
      </div>

      <!-- JOB INFO -->
      <div class="success-job mt-10">
        <h2 class="success-job-title text-xl font-bold text-slate-800">
          {appliedJobTitle}
        </h2>

        <div
          class="success-meta flex items-center justify-center gap-3 mt-4 text-slate-500 text-base"
        >
          <div class="flex items-center gap-1.5">
            <BriefcaseBusiness size={16} />
            <span>Tim Teknologi Global</span>
          </div>

          <div class="flex items-center gap-1.5">
            <MapPin size={16} />
            <span>Surabaya</span>
          </div>
        </div>
      </div>

      <!-- WARNING BOX -->
      <div
        class="success-warning mt-10 bg-[#eef3ff] border border-[#d7e1ff] rounded-3xl p-6 text-left shadow-sm"
      >
        <div class="flex items-start gap-3">
          <TriangleAlert class="text-red-500 mt-0.5 shrink-0" size={22} />

          <div class="flex-1">
            <h3 class="font-semibold text-slate-800 text-lg">Attention</h3>

            <p class="text-slate-600 mt-2 leading-relaxed">
              Please save this application ID as it will not appear a second
              time.
            </p>

            <!-- LINK BOX -->
            <div
              class="mt-5 bg-white border border-slate-200 rounded-2xl px-5 py-4 flex items-center justify-between"
            >
              <span class="text-slate-500 text-sm truncate">
                {applicationId || "Application ID belum tersedia"}
              </span>

              <button
                type="button"
                id="copyButton"
                disabled={!applicationId}
                class="text-blue-500 hover:text-blue-600 transition"
              >
                <Copy size={20} />
              </button>
            </div>
          </div>
        </div>
      </div>

      <!-- INFO BOX -->
      <div
        class="success-info mt-6 bg-[#eef3ff] border border-[#d7e1ff] rounded-3xl p-6 text-left shadow-sm"
      >
        <div class="flex items-start gap-3">
          <Info class="text-blue-500 mt-0.5 shrink-0" size={22} />

          <div>
            <h3 class="font-semibold text-slate-800 text-lg">
              How to Use Links
            </h3>

            <div class="mt-3 space-y-2 text-slate-600 leading-relaxed">
              <p>Go back to the job page and click the application button.</p>

              <p>Paste the application ID and click Start Tracking.</p>

              <p>Then you will see the status of your application.</p>
            </div>
          </div>
        </div>
      </div>

      <!-- BUTTON -->
      <div class="success-button-wrap mt-10">
        <a
          href="/jobs"
          class="success-button inline-flex items-center justify-center bg-blue-500 hover:bg-blue-600 transition text-white font-medium px-8 py-4 rounded-full shadow-lg shadow-blue-200"
        >
          Go Back to Job Page
        </a>
      </div>
    </div>
  </section>

  <!-- COPY SCRIPT -->
  <script define:vars={{ applicationId }}>
    const copyButton = document.getElementById("copyButton");

    copyButton?.addEventListener("click", async () => {
      if (!applicationId) {
        return;
      }

      try {
        await navigator.clipboard.writeText(applicationId);

        copyButton.innerHTML = `
          <svg xmlns="http://www.w3.org/2000/svg"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round">
            <path d="M20 6 9 17l-5-5"/>
          </svg>
        `;

        setTimeout(() => {
          copyButton.innerHTML = `
            <svg xmlns="http://www.w3.org/2000/svg"
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round">
              <rect width="14" height="14" x="8" y="8" rx="2" ry="2"/>
              <path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/>
            </svg>
          `;
        }, 2000);
      } catch (err) {
        console.error("Failed to copy:", err);
      }
    });
  </script>
</MainLayout>

<style>
  .success-hero,
  .success-content,
  .success-icon-wrap,
  .success-icon,
  .success-icon-core,
  .success-title-wrap,
  .success-title,
  .success-subtitle,
  .success-job,
  .success-job-title,
  .success-meta,
  .success-warning,
  .success-info,
  .success-button-wrap,
  .success-button {
    opacity: 0;
    transform: translateY(14px);
    animation: successFadeUp 700ms cubic-bezier(0.22, 1, 0.36, 1) forwards;
    will-change: opacity, transform;
  }

  .success-hero {
    animation-delay: 0ms;
  }

  .success-content {
    animation-delay: 80ms;
  }

  .success-icon-wrap {
    animation-delay: 160ms;
  }

  .success-icon {
    animation-delay: 220ms;
  }

  .success-icon-core {
    animation-delay: 300ms;
  }

  .success-title-wrap {
    animation-delay: 380ms;
  }

  .success-title {
    animation-delay: 460ms;
  }

  .success-subtitle {
    animation-delay: 540ms;
  }

  .success-job {
    animation-delay: 620ms;
  }

  .success-job-title,
  .success-meta {
    animation-delay: 700ms;
  }

  .success-warning {
    animation-delay: 780ms;
  }

  .success-info {
    animation-delay: 860ms;
  }

  .success-button-wrap {
    animation-delay: 940ms;
  }

  .success-button {
    animation-delay: 1020ms;
  }

  @keyframes successFadeUp {
    from {
      opacity: 0;
      transform: translateY(14px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .success-hero,
    .success-content,
    .success-icon-wrap,
    .success-icon,
    .success-icon-core,
    .success-title-wrap,
    .success-title,
    .success-subtitle,
    .success-job,
    .success-job-title,
    .success-meta,
    .success-warning,
    .success-info,
    .success-button-wrap,
    .success-button {
      opacity: 1;
      transform: none;
      animation: none;
    }
  }
</style>
<!-- josjis -->
<!-- baru -->

<script>
  // Remove sensitive query params from address bar without reloading
  try {
    if (window && window.history && window.location) {
      const url = new URL(window.location.href);
      let changed = false;
      ["application_id", "applicationId", "application"].forEach((k) => {
        if (url.searchParams.has(k)) {
          url.searchParams.delete(k);
          changed = true;
        }
      });

      if (changed) {
        const newUrl =
          url.pathname +
          (url.search ? `?${url.searchParams.toString()}` : "") +
          url.hash;
        window.history.replaceState({}, document.title, newUrl);
      }
    }
  } catch (e) {
    // ignore
  }
</script>
